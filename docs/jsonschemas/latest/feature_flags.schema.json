{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kenfigure.com/jsonschemas/latest/feature_flags.schema.json",
  "title": "Feature flags",
  "description": "Feature flags. Back-end settings that must be fetched and changed by Benchling.",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "additionalProperties": {
      "type": "object",
      "required": ["Current", "Default", "Description"],
      "properties": {
        "Current": {
          "type": ["string", "boolean"]
        },
        "Default": {
          "type": ["string", "boolean"]
        },
        "Description": {
          "type": ["string", "boolean"]
        },
        "Planned": {
          "type": ["string", "boolean"],
          "nullable": true
        }
      },
      "additionalProperties": false
    }
  }
}
